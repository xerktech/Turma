#!/usr/bin/env bash
# turma-agent — native (non-Docker) launcher for the Turma per-host agent.
#
# This is the RUNTIME HALF of agent/entrypoint.sh, minus every container and
# privilege-drop bit. A native install runs directly as the invoking user, whose
# $HOME and repo ownership are already correct, so there is NO setpriv, no
# uid/gid resolution, no chown, no docker-socket group join, and HOME is never
# forced — the very machinery entrypoint.sh needs only because it boots as root
# inside a container.
#
# It sources the config env file, sets native-safe defaults (notably pointing
# CLAUDE_PROJECTS_ROOT at the real $HOME instead of the container's /root), does
# a log-only credentials preflight (idling ONLY when the Claude login is
# missing), (re)starts the outbound reverse tunnel, then exec's the session
# manager as the long-lived foreground process.
set -eu

# Resolve the install prefix from our own location ($PREFIX/bin/turma-agent).
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"   # $PREFIX/bin
PREFIX="$(dirname "$SELF_DIR")"             # $PREFIX

# Load config. Same plain KEY=value format systemd's EnvironmentFile consumes;
# `set -a` exports every assignment so it reaches hub-agent.py as an env var.
CFG="${TURMA_AGENT_ENV:-${XDG_CONFIG_HOME:-$HOME/.config}/turma-agent/turma-agent.env}"

# Every non-assignment line in the config, as `<line#>:<text>`. We SOURCE this
# file, so such a line is not an inert typo — it RUNS. A YAML-style
# `JIRA_SITE: "..."` becomes the command `JIRA_SITE:`, which exits 127 and, under
# `set -e`, takes the launcher with it before it ever execs the manager.
#
# That is a uniquely bad way to fail, because the two readers of this file
# DISAGREE about it: systemd's EnvironmentFile parser merely warns ("Ignoring
# invalid environment assignment") and carries on, while our `.` dies. With
# Restart=always the unit then rebuilds every RestartSec forever — a loop spaced
# just wide enough to stay under systemd's start-rate limit, so it never trips
# the "failed" state that would make it visible. Each pass reaps and respawns the
# tunnel, so every session on the host reads "terminal offline", and the only
# evidence is one `command not found` per interval in the journal.
#
# Anchoring on the `=` directly after the name is the point: `JIRA_TOKEN: "a=b"`
# has an `=` in its VALUE and slips past any looser check. A `#` comment, a blank
# line, and an `export` prefix all stay legal — `export` is not the documented
# format, but sourcing has always accepted it and this must not fail a config
# that works today. Line-based, so a quoted value spanning lines reads as
# invalid; systemd rejects those too, which is why the format has never had them.
config_errors() {  # <file>
  grep -nvE '^[[:space:]]*(#|$)|^[[:space:]]*(export[[:space:]]+)?[A-Za-z_][A-Za-z0-9_]*=' "$1" || true
}

CFG_BAD=""
if [ -f "$CFG" ]; then
  CFG_BAD="$(config_errors "$CFG")"
  if [ -z "$CFG_BAD" ]; then
    set -a
    # shellcheck disable=SC1090
    . "$CFG"
    set +a
  fi
fi

# A bad config is reported ONCE and then idled on — the same posture as the
# missing Claude login below, and for the same reason: idling is self-healing
# (fix the file, restart the unit) and it states the problem where an operator
# will actually read it. Never `exit 1` here. That is precisely what produced the
# invisible crash loop; a launcher that refuses to start is indistinguishable, to
# systemd, from one that is worth starting again in five seconds.
#
# Nothing is sourced in this state: a half-applied config would leave the manager
# reporting to the wrong hub, or none, which is worse than not running.
if [ -n "$CFG_BAD" ]; then
  # Report the line NUMBER and the leading name only — never the line. This file
  # is chmod 600 and holds TURMA_TOKEN and JIRA_TOKEN, while this banner goes to
  # the journal, which is a different audience with different permissions. A
  # malformed secret is still a secret. (systemd's own warning for these lines
  # does echo the value, which is not a reason for us to leak it a second time.)
  # The name is all an operator needs to find the line in their editor.
  cfg_bad_report() {
    echo "$CFG_BAD" | awk '{
      line = $0; sub(/^[0-9]+:/, "", line); num = $0; sub(/:.*$/, "", num)
      sub(/^[ \t]+/, "", line)
      name = (match(line, /^[A-Za-z_][A-Za-z0-9_]*/)) ? substr(line, 1, RLENGTH) : "(unreadable)"
      printf "   line %s: %s ...\n", num, name
    }'
  }
  echo "=================================================================="
  echo " Invalid line(s) in $CFG"
  echo " (values hidden — this file holds tokens; only names are shown)"
  echo
  cfg_bad_report
  echo
  echo " Expected plain KEY=value, one per line (the format systemd's"
  echo " EnvironmentFile takes). A line like  JIRA_SITE: \"x\"  is YAML, not"
  echo " shell: it runs as a command, and the agent cannot start."
  echo
  echo " Nothing from this file was loaded. Fix the line(s) above, then:"
  echo "   systemctl --user restart turma-agent"
  echo "=================================================================="
  # --preflight is install.sh --verify's reporting hook: it must answer and
  # leave, never hang. Every other entry point (the run path, and the tunnel
  # supervisor that inherits this config) idles.
  if [ "${1:-}" = "--preflight" ]; then exit 1; fi
  exec sleep infinity
fi

# Native-safe defaults, applied only when the config left a key blank/unset (the
# `:-` treats an empty value as unset, which is why the template ships these
# blank). PATH gets $PREFIX/bin so a bundled static ttyd is found.
export PATH="$PREFIX/bin:$PATH"
export CLAUDE_PROJECTS_ROOT="${CLAUDE_PROJECTS_ROOT:-$HOME/.claude/projects}"
export REPOS_ROOT="${REPOS_ROOT:-$HOME/git}"
export DEVICE_NAME="${DEVICE_NAME:-$(hostname)}"
TUNNEL_RETRY_SEC="${TUNNEL_RETRY_SEC:-10}"

CREDS="$HOME/.claude/.credentials.json"

# ---- reverse-tunnel supervisor ---------------------------------------------
# Re-entry point: `turma-agent --tunnel-supervisor`, backgrounded by the run
# path below. It is this script rather than a file of its own so that the
# supervisor inherits the config we just sourced (TURMA_URL/TURMA_TOKEN and the
# PATH above are what the tunnel needs), and so that its argv carries a precise,
# greppable key — the run path and turma-agentctl both pkill on it. That key is
# PREFIX-scoped, like the tunnel-agent.js one, so a --prefix install only ever
# reaps its own.
#
# The tunnel is SUPERVISED here with a node check, because a native
# install is the only place its runtime can be missing: node is an apt
# prerequisite installed at setup time, not a baked image layer. Fire-and-forget
# made that failure both silent and permanent — the manager kept heartbeating,
# so the host read ONLINE in the UI while every one of its sessions read
# "terminal offline", with a lone `node: command not found` in the journal to
# say why. Nothing retried, because nothing was watching.
#
# So the node check lives INSIDE the loop, not in front of it: installing node
# on a host that came up without it heals the terminals within one retry, with
# no restart and no operator who has to know a restart was owed.
if [ "${1:-}" = "--tunnel-supervisor" ]; then
  while :; do
    if command -v node >/dev/null 2>&1; then
      rc=0; node "$PREFIX/tunnel-agent.js" || rc=$?
      echo "[turma-agent] tunnel exited (rc=$rc); web terminals are offline until it is back"
    else
      echo "[turma-agent] node not on PATH — the reverse tunnel cannot start, so every"
      echo "[turma-agent] session on this host reads 'terminal offline'. Install node >=" \
           "22 (the installer does this: agent/native/install.sh); it is picked up here."
    fi
    sleep "$TUNNEL_RETRY_SEC"
  done
fi

# Log-only creds preflight, mirroring entrypoint.sh's checks but pointed at the
# real $HOME. Never fatal here — the claude idling case is handled separately in
# the run path so `--preflight` can report without hanging.
report_creds() {
  if [ -f "$CREDS" ]; then
    echo "[turma-agent] claude: subscription credentials present"
  else
    echo "[turma-agent] claude: NO credentials at $CREDS — run 'claude /login' on this host"
  fi
  if command -v gh >/dev/null 2>&1; then
    if gh auth status >/dev/null 2>&1; then
      echo "[turma-agent] gh: authenticated as $(gh api user -q .login 2>/dev/null || echo '?')"
    else
      echo "[turma-agent] gh: NOT authenticated — private git ops and 'gh pr create' will fail (run: gh auth login)"
    fi
  fi
  # Cloud CLIs are optional and usually absent natively; the command -v guard
  # makes this silently no-op. Keyed on a login-marker FILE, never the store dir
  # (each CLI creates its own store just by running) — same rule as entrypoint.sh.
  for pair in "aws:$HOME/.aws/credentials" \
              "az:$HOME/.azure/msal_token_cache.json" \
              "terraform:$HOME/.terraform.d/credentials.tfrc.json"; do
    cli="${pair%%:*}"; marker="${pair#*:}"
    command -v "$cli" >/dev/null 2>&1 || continue
    if [ -e "$marker" ]; then
      echo "[turma-agent] $cli: host creds present"
    else
      echo "[turma-agent] $cli: installed; no creds on this device — ignoring"
    fi
  done
}

# Report-only mode for install.sh --verify: no idling, no launches.
if [ "${1:-}" = "--preflight" ]; then
  echo "[turma-agent] preflight (PREFIX=$PREFIX)"
  report_creds
  for t in claude git tmux ttyd node python3; do
    if command -v "$t" >/dev/null 2>&1; then
      echo "[turma-agent] tool $t: $(command -v "$t")"
    else
      echo "[turma-agent] tool $t: MISSING"
    fi
  done
  exit 0
fi

report_creds

# The one fatal check: Remote Control needs a subscription OAuth login. Idle
# rather than crash-loop, so a systemd service self-heals the moment the user
# logs in on the host without needing a manual restart.
if [ ! -f "$CREDS" ]; then
  echo "=================================================================="
  echo " No Claude subscription credentials at $CREDS"
  echo
  echo " Log in on this host:   claude /login"
  echo " (Remote Control requires a subscription OAuth login; a setup-token"
  echo "  is inference-only and can't host RC.)"
  echo
  echo " Idling until credentials exist..."
  echo "=================================================================="
  exec sleep infinity
fi

# Reconcile the reverse tunnel: kill any prior instance first, so each (re)start
# replaces the tunnel with the current code and never leaves a duplicate. This
# matters because the systemd unit uses KillMode=process — on a manager restart
# the old tunnel survives, and we want exactly one. Restarting the tunnel only
# blips the web UI; it never touches tmux/claude.
#
# The supervisor goes first and the tunnel second: the reverse order would have
# the old supervisor respawn the tunnel we just killed, and we would adopt it as
# ours. setsid so the loop leads its own session — it must outlive this shell,
# which `exec`s the manager below.
pkill -f "$SELF_DIR/turma-agent --tunnel-supervisor" 2>/dev/null || true
pkill -f "$PREFIX/tunnel-agent.js" 2>/dev/null || true

# The pid the tunnel pokes to cut a heartbeat sleep short. `exec` preserves the
# pid, so this shell's $$ IS the manager's pid a few lines down — which is the
# only way to name it before it exists. The container gets this for free (its
# manager is PID 1, the tunnel's fallback); here PID 1 is systemd, and poking it
# just earned an EPERM every time, quietly costing every hub command up to a
# whole beat of latency.
export TURMA_MANAGER_PID="$$"
setsid "$SELF_DIR/turma-agent" --tunnel-supervisor &

echo "[turma-agent] starting session manager (REPOS_ROOT=$REPOS_ROOT DEVICE_NAME=$DEVICE_NAME)"
exec python3 "$PREFIX/hub-agent.py"
