# Copy to .env next to the compose file and edit. Never commit the result.
#
#   cp .env.example .env
#
# Naming note: the agent-side inputs below are deliberately NOT named after the
# variables they set inside the container (HUB_URL sets TURMA_URL,
# HOST_REPOS_ROOT sets the REPOS_ROOT mount, and so on). Compose lets the
# calling shell's environment override this file, and every agent container
# exports TURMA_URL / TURMA_TOKEN / REPOS_ROOT / DEVICE_NAME / MAX_SESSIONS /
# JIRA_* itself — so a same-named input would be silently ignored for anyone
# running compose from inside a Turma session, pointing their new agent at
# whatever hub that session belongs to. Keep compose inputs and container
# variables named apart.

# --- Hub auth -----------------------------------------------------------------
# The single operator login for the dashboard and its APIs. If TURMA_PASSWORD is
# empty the hub serves the whole UI unauthenticated and only warns about it.
TURMA_USER=admin
TURMA_PASSWORD=change-me

# Shared secret between the hub and every agent. On the hub it lands as
# TURMA_AGENT_TOKEN; inside an agent, as TURMA_TOKEN. Use the same value for
# both, on every host in the fleet.
# Generate one with:  openssl rand -hex 32
TURMA_AGENT_TOKEN=change-me-too

# Optional. Bearer token for POST /api/trigger, so CI or a webhook can start a
# session without the operator login.
# TURMA_TRIGGER_TOKEN=

# --- Agent --------------------------------------------------------------------
# The hub URL as seen FROM this agent host. On the all-in-one compose both
# containers share a network, so the service name works. For an agent on any
# other machine, use the hub's public URL (https://turma.example.com).
HUB_URL=http://turma:8300

# The git root on THIS host to scan for repos, one level deep. Absolute path.
# Host side only — inside the container it is always mounted at /repos.
HOST_REPOS_ROOT=/home/you/git

# How this host appears in the hub. Must be distinct per host in a fleet.
# Falls back to a docker/SMB probe when unset.
AGENT_DEVICE_NAME=my-host

# Concurrent sessions on this host.
AGENT_MAX_SESSIONS=6

# Resource ceilings for the agent container. Size against AGENT_MAX_SESSIONS,
# not against a single session.
AGENT_MEM_LIMIT=12g
AGENT_CPUS=6

# --- Optional integrations ----------------------------------------------------
# ntfy alerts (hub): host offline, question waiting, PR opened, cost threshold.
# NTFY_URL=https://ntfy.example.com
# NTFY_TOPIC=agents
# NTFY_USER=
# NTFY_PASS=

# Whisper STT for glasses/Android dictation (hub). Any OpenAI-compatible /v1
# base; the hub derives /audio/transcriptions from it.
# LITELLM_URL=https://litellm.example.com/v1
# LITELLM_API_KEY=

# FCM push to the Android client (hub). Inline service-account JSON.
# FCM_SERVICE_ACCOUNT_JSON=

# Jira board (agent). All three unset = feature off, zero Jira calls. Read-only.
# Uncomment the matching lines in agent.yaml too.
# AGENT_JIRA_SITE=https://your-org.atlassian.net
# AGENT_JIRA_EMAIL=you@example.com
# AGENT_JIRA_TOKEN=
# Opt-in, per-org: auto-start a session for every "To Do" ticket the moment it has
# a repo assigned (off by default; sessions still spread across all the org's
# agents). Named TICKET_* because it isn't Jira-specific — other boards may back it.
# AGENT_TICKET_AUTO_START=1

# Extra owners in the hub's clone dropdown, beyond the gh login's own repos and
# orgs (agent). Comma-separated.
# AGENT_GH_CLONE_OWNERS=
