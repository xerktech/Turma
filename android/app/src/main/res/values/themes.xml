<resources>
    <!-- Launch theme only; the UI itself is Jetpack Compose Material3. The
         window background is the DayNight page color (values / values-night) so
         the pre-Compose flash matches the active theme, and the system bars are
         driven edge-to-edge by TurmaTheme, not here. -->
    <style name="Theme.Turma" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/turma_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
